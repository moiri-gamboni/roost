{
  "cleanupPeriodDays": 99999,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "ENABLE_PROMPT_CACHING_1H": "1",
    "CLAUDE_CODE_SCROLL_SPEED": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "permissions": {
    "allow": [
      "Read",
      "WebSearch",
      "WebFetch",
      "mcp__exa__web_search_exa",
      "mcp__exa__web_fetch_exa",
      "mcp__notion__API-get-*",
      "mcp__notion__API-retrieve-*",
      "mcp__notion__API-list-data-source-templates",
      "mcp__notion__API-post-search",
      "mcp__notion__API-query-data-source"
    ],
    "ask": [
      "mcp__notion__API-patch-*",
      "mcp__notion__API-update-*",
      "mcp__notion__API-create-*",
      "mcp__notion__API-delete-*",
      "mcp__notion__API-post-page",
      "mcp__notion__API-move-page"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [],
    "PreCompact": [],
    "Stop": [],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/roost/claude/hooks/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/roost/claude/hooks/statusline.sh"
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": false,
    "praxis@praxis-marketplace": true,
    "serena@claude-plugins-official": true,
    "strip-images@claude-strip-images": true
  },
  "extraKnownMarketplaces": {
    "claude-strip-images": {
      "source": {
        "source": "github",
        "repo": "moiri-gamboni/claude-strip-images"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "autoCompactEnabled": false,
  "teammateMode": "tmux",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": false,
  "skipAutoPermissionPrompt": true
}
