# ProtonVPN WireGuard config — TEMPLATE.
#
# Copy to /etc/wireguard/proton.conf (owned root:root, mode 0600) and replace
# every <bracketed placeholder> with values from the Proton dashboard
# (https://account.protonvpn.com/downloads, WireGuard tab).
#
# Generate the config on the Proton dashboard with IPv6 enabled; without that,
# the Address line below will lack a v6 entry and the ip6tables kill-switch will
# have no v6 egress to gate — leaking IPv6 past Proton.
#
# After editing:
#   sudo install -m 0600 -o root -g root proton.conf /etc/wireguard/proton.conf
#   sudo roost-net vpn on
#
# See plans/travel-vpn-architecture.md §6 "Pre-departure".

[Interface]
# Private key generated and shown once on the Proton dashboard (cannot be retrieved later).
PrivateKey = <PRIVATE_KEY_FROM_PROTON>

# Tunnel interior addresses. Proton assigns both v4 and v6 when IPv6 is enabled in the config generator.
# Keep both — the server's kill-switch and policy routing assume dual-stack parity.
Address = 10.2.0.2/32, fd7a::2/128

# Table = off disables wg-quick's automatic default-route install. proton-routing.sh
# manages the Proton routing table (51820) and policy rules instead.
Table = off

# DNS = (empty) prevents wg-quick from rewriting resolv.conf. Xray resolves via
# the system resolver (Cloudflare DoH on the client side); the server doesn't need
# to route DNS through Proton for this architecture.
DNS =

# Routing + kill-switch lifecycle. PostUp installs fwmark policy, kill-switch,
# rp_filter tweaks; PreDown undoes them. A trap inside the script rolls back on
# partial failure, so wg-quick up either succeeds fully or leaves nothing behind.
PostUp = /etc/roost-travel/proton-routing.sh up
PreDown = /etc/roost-travel/proton-routing.sh down

[Peer]
# Proton server public key (fixed per server, shown on the dashboard).
PublicKey = <SERVER_PUBLIC_KEY_FROM_PROTON>

# Proton server endpoint. Prefer a hostname so DNS resolves A + AAAA; proton-routing.sh
# reads both and adds exclusion rules for each family. Pick a country close to
# Hetzner for latency (e.g. ch-1.protonvpn.net for Switzerland).
Endpoint = <COUNTRY>.protonvpn.net:51820

# Route all traffic into the tunnel. Combined with Table = off above, this is
# harmless (wg doesn't touch routes); policy routing in PostUp does the work.
AllowedIPs = 0.0.0.0/0, ::/0

# Optional but recommended when NAT traversal is involved; Proton's default is 25s.
PersistentKeepalive = 25
