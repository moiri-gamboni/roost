# ProtonVPN WireGuard profile — drop in raw, no editing required.
#
# Workflow:
#
#   1. Download each variant from https://account.protonvpn.com/downloads
#      (WireGuard tab → enable IPv6 → pick country → pick NetShield setting).
#   2. Install each under /etc/roost-travel/proton-profiles/<NAME>.conf as-is:
#        sudo install -m 0600 -o root -g root ch-netshield.conf \
#            /etc/roost-travel/proton-profiles/netshield.conf
#        sudo install -m 0600 -o root -g root ch-clean.conf \
#            /etc/roost-travel/proton-profiles/clean.conf
#   3. Activate one:
#        roost-net vpn profile netshield   # synthesizes /etc/wireguard/wg-proton.conf
#   4. Toggle VPN:
#        roost-net vpn on
#   5. Switch later (hot-swap, auto-restarts wg-quick if vpn=on):
#        roost-net vpn profile clean
#
# `vpn profile` strips any Table/PostUp/PreDown/DNS lines from the source and
# re-injects the roost-canonical values:
#
#   Table = off                                            # wg-quick: skip auto-routing
#   DNS =                                                  # wg-quick: don't rewrite resolv.conf
#   PostUp  = /etc/roost-travel/proton-routing.sh up       # install fwmark policy + kill-switch
#   PreDown = /etc/roost-travel/proton-routing.sh down     # tear them back down
#
# Those four are roost-level concerns, identical across profiles — keeping them
# out of the source means profiles drop in as raw downloads, no per-profile
# hand-editing, and forgetting them can no longer brick the tunnel + kill
# Tailscale (the failure mode behind the May 2026 outage).
#
# IPv6 is mandatory for the kill-switch to be meaningful: without v6 in the
# profile's Address, ip6tables REJECT rules have no egress to gate and v6
# leaks. Proton's config generator includes v6 automatically when IPv6 is
# enabled at download time.
#
# Reference shape (raw Proton output — what you should be installing):
#
#   [Interface]
#   PrivateKey = <PRIVATE_KEY_FROM_PROTON>
#   Address = 10.2.0.2/32, fd7a::2/128
#   DNS = 10.2.0.1, fd7a::1
#
#   [Peer]
#   PublicKey = <SERVER_PUBLIC_KEY_FROM_PROTON>
#   AllowedIPs = 0.0.0.0/0, ::/0
#   Endpoint = <country>.protonvpn.net:51820
#   PersistentKeepalive = 25
