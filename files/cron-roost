# Environment
HOME=$HOME_DIR
ROOST_DIR_NAME=$ROOST_DIR_NAME
CLAUDE_CONFIG_DIR=$HOME_DIR/$ROOST_DIR_NAME/claude
BASH_ENV=$HOME_DIR/.bashrc.d/roost.sh

# Health check every 5 minutes
*/5 * * * * $USERNAME flock -n $HOME_DIR/.locks/health-check $HOME_DIR/$ROOST_DIR_NAME/claude/hooks/health-check.sh

# Morning summary
0 8 * * * $USERNAME flock -n $HOME_DIR/.locks/morning-summary $HOME_DIR/$ROOST_DIR_NAME/claude/hooks/scheduled-task.sh "Check ntfy history and summarize what happened overnight" $HOME_DIR/$ROOST_DIR_NAME/code/life

# Weekly memory cleanup — DISABLED. The ~/memory note system is not in use.
# To re-enable, uncomment the line below and roost-apply push.
#0 10 * * 0 $USERNAME flock -n $HOME_DIR/.locks/memory-cleanup $HOME_DIR/$ROOST_DIR_NAME/claude/hooks/scheduled-task.sh "Review ~/$ROOST_DIR_NAME/memory/ for duplicate or mergeable notes. Deduplicate and merge where appropriate. Do not delete notes that passed the 6-month test at write time unless you can document a clear reason in the commit message." $HOME_DIR/$ROOST_DIR_NAME/code/life

# Weekly auto-update (Sunday 3am)
0 3 * * 0 $USERNAME flock -n $HOME_DIR/.locks/auto-update $HOME_DIR/$ROOST_DIR_NAME/claude/hooks/auto-update.sh

# Weekly Travel-VPN audit (Sunday 4am): roost-net test when vpn=on. cmd_test ntfy_sends on failure so no extra wrapper is needed.
0 4 * * 0 $USERNAME flock -n $HOME_DIR/.locks/travel-audit sh -c 'if [ "$(cat /etc/roost-travel/vpn)" = "on" ]; then $HOME_DIR/$ROOST_DIR_NAME/claude/hooks/roost-net.sh test; fi'

# Daily Vision (Path D) abuse watch: ntfy on novel client IPs hitting the
# Vision inbound. Skips silently if /var/log/xray/access.log doesn't exist.
30 5 * * * $USERNAME flock -n $HOME_DIR/.locks/vision-abuse-watch $HOME_DIR/$ROOST_DIR_NAME/claude/hooks/vision-abuse-watch.sh

# Agents-list cleanup — DISABLED. Reverted to built-in `claude agents`
# behavior. To re-enable, uncomment both lines below and roost-apply push.
# The scripts themselves remain deployed at ~/$ROOST_DIR_NAME/claude/hooks/.
# Tag agents-cleanup-v1 marks the working version, in case of revert.
#
# Minute-tick: touch ~/$ROOST_DIR_NAME/claude/last-connection-activity if any
# SSH (22) or ET (2022) connection is alive. Used by agents-cleanup.sh as a
# "is the user around" gate. No flock — operation is idempotent and trivial.
#* * * * * $USERNAME $HOME_DIR/$ROOST_DIR_NAME/claude/hooks/track-ssh-activity.sh
#
# Daily agents-list cleanup (3:30am): drop done/stopped/failed/crashed sessions
# idle ≥48 weekday hours, only if a connection-activity marker is ≤24h old.
# Uses rm -rf jobs/<id> — preserves transcripts and worktrees.
#30 3 * * * $USERNAME flock -n $HOME_DIR/.locks/agents-cleanup $HOME_DIR/$ROOST_DIR_NAME/claude/hooks/agents-cleanup.sh
