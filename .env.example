# ============================================
# Claude Roost Configuration
# ============================================
# Fill in all required values before running any scripts.
#
# Hetzner API auth: configure via `hcloud context create roost`
# (the token is stored by hcloud, not in this file)

# --- Hetzner ---
SERVER_NAME="roost"       # Your choice; shown in Hetzner console and hcloud CLI
SERVER_TYPE="cx43"          # 8 vCPU, 16GB RAM
SERVER_LOCATION=""          # Optional: comma-separated list, tried in order (e.g. "nbg1,fsn1")
                            # Only listed locations are tried. Empty = auto (all, Western Europe first)
SSH_KEY_NAME=""              # Optional: name of your SSH key in Hetzner. If empty, you'll be
                            # prompted to select or upload one interactively.

# --- Server User ---
USERNAME=""

# --- Domain ---
DOMAIN=""

# --- Roost directory name ---
ROOST_DIR_NAME="roost"      # Name of the managed directory under ~/

# --- Cloudflare ---
CLOUDFLARE_TUNNEL_NAME=""   # Defaults to $ROOST_DIR_NAME if empty
# Required: API token with Account > Cloudflare Tunnel > Edit and Zone > DNS > Edit.
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""    # Optional: speeds up tunnel creation by skipping account lookup

# --- Tailscale ---
# Tagged auth key (tag:server) for unattended setup.
# First add tagOwners to your ACL policy, then generate a tagged key.
# Generate at: https://login.tailscale.com/admin/settings/keys (select tag: server)
TAILSCALE_AUTHKEY=""

# --- Tailscale API ---
# Optional: API key for setting ACL policy automatically during deploy.
# Generate at: https://login.tailscale.com/admin/settings/keys (API key, not auth key)
# Expires in 1-90 days; only needed during deploy. If empty, set ACLs manually.
TAILSCALE_API_KEY=""

# --- GitHub ---
# No token here. Git uses SSH: deploy generates an ed25519 key on the server;
# register it on GitHub for authentication + signing (one-time, manual).
# gh's API auth is also a one-time manual step after deploy: ssh in and run
# `gh auth login` (OAuth). No PATs to create, store, or rotate.

# --- Notion ---
# Notion internal integration token (workspace-level or per-page).
# Create/manage at https://www.notion.so/profile/integrations and share the
# relevant pages/databases with it (workspace-level integrations see everything).
# Passed to the Notion MCP server via `claude mcp add ... -e NOTION_TOKEN=...`
# (baked into ~/roost/claude/.claude.json by deploy.sh). Write tools are gated
# behind a permissions.ask rule in files/settings.json; reads are allow-listed.
NOTION_TOKEN=""

# --- DoneThat ---
# DoneThat REST API key (x-api-key header) for read-only reporting via
# https://api.donethat.ai. Deployed to ~/.config/donethat/api-key (0600).
# NOTE: DoneThat's MCP server uses OAuth, not this key. After deploy, run once:
#   claude mcp login donethat --no-browser
# (paste-URL flow; no port-forwarding needed). Claude Code stores/refreshes the
# OAuth token itself, so there is no MCP credential to put here.
DONETHAT_API_KEY=""
