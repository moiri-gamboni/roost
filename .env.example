# ============================================
# Claude Roost Configuration
# ============================================
# Fill in all required values before running any scripts.

# --- Hetzner ---
# API token: https://console.hetzner.cloud/ > your project > Security > API Tokens
HETZNER_API_TOKEN=""
SERVER_NAME="self-host"       # Your choice; shown in Hetzner console and hcloud CLI
SERVER_TYPE="cx43"          # 8 vCPU, 16GB RAM
SERVER_LOCATION=""          # Optional: comma-separated list, tried in order (e.g. "nbg1,fsn1")
                            # Only listed locations are tried. Empty = auto (all, Western Europe first)
SSH_KEY_NAME=""              # Name of your SSH key in Hetzner (add via console or hcloud first)

# --- Server User ---
USERNAME=""

# --- Domain ---
DOMAIN=""

# --- Cloudflare ---
CLOUDFLARE_TUNNEL_NAME="hetzner-server"

# --- Tailscale ---
# Optional: pre-authenticated key for unattended setup.
# Generate at: https://login.tailscale.com/admin/settings/keys
# Leave empty to authenticate interactively via browser.
TAILSCALE_AUTHKEY=""

# --- Notifications ---
NTFY_TOPIC="claude-${USERNAME}"
